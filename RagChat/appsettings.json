{
  "RagSystem": {
    "DocumentProcessing": {
      "ChunkSize": 800,
      "ChunkOverlap": 100,
      "SupportedExtensions": [ ".pdf", ".txt", ".docx", ".md" ],
      "MaxConcurrentProcessing": 2,
      "MaxDocumentSizeMB": 50,
      "EnableOcr": false,
      "TempDirectory": "temp"
    },
    "EmbeddingModel": {
      "ModelPath": "../models/all-MiniLM-L6-v2.onnx",
      "Dimension": 384,
      "MaxSequenceLength": 512,
      "UseGpu": false,
      "BatchSize": 16,
      "Provider": "ONNX"
    },
    "VectorStore": {
      "ConnectionString": "",
      "Provider": "SQLite",
      "DatabasePath": "data/vectors.db",
      "QueryBatchSize": 50,
      "IndexBatchSize": 25,
      "EnableWalMode": true,
      "ConnectionTimeoutSeconds": 30,
      "ProviderSettings": {}
    },
    "Llm": {
      "BaseUrl": "http://localhost:11434",
      "Model": "deepseek-r1:7b",
      "Temperature": 0.7,
      "MaxTokens": 1024,
      "TopP": 0.9,
      "TopK": 40,
      "RepetitionPenalty": 1.1,
      "TimeoutSeconds": 60,
      "ApiKey": "",
      "AdditionalParameters": {},
      "Provider": "Ollama"
    },
    "Rag": {
      "MaxChunks": 5,
      "SimilarityThreshold": 0.7,
      "EnableReranking": false,
      "SystemPrompt": "You are a helpful assistant that answers questions based on the provided context. If you cannot find relevant information in the context, please say so clearly.",
      "MaxConcurrentQueries": 2,
      "EnableCaching": true,
      "CacheTtlSeconds": 300
    },
    "RetryPolicy": {
      "MaxRetries": 3,
      "BaseDelayMs": 1000,
      "BackoffMultiplier": 2.0,
      "MaxDelayMs": 10000,
      "EnableJitter": true,
      "RetriableExceptions": [
        "HttpRequestException",
        "TaskCanceledException",
        "SqliteException"
      ]
    },
    "Performance": {
      "EnableMetrics": true,
      "EnableTracing": false,
      "MetricsIntervalSeconds": 60,
      "LogSlowOperations": true,
      "SlowOperationThresholdMs": 2000,
      "TrackedOperations": [
        "VectorSearch",
        "LlmInference",
        "EmbeddingGeneration"
      ]
    },
    "Memory": {
      "MaxDocumentCacheSizeMB": 100,
      "MaxEmbeddingCacheSizeMB": 50,
      "EnableGarbageCollectionTuning": true,
      "GcPressureThresholdMB": 30,
      "EnableMemoryPressureCallback": true,
      "MemoryWarningThresholdPercent": 80
    },
    "Shutdown": {
      "GracefulShutdownTimeoutSeconds": 30,
      "WaitForActiveOperations": true,
      "SaveStateOnShutdown": false,
      "StateFilePath": "data/chat-shutdown-state.json",
      "EnableShutdownMetrics": true
    },
    "Logging": {
      "MinimumLevel": "Information",
      "EnableConsoleLogging": true,
      "EnableFileLogging": false,
      "LogFilePath": "logs/chat-{Date}.log",
      "EnableStructuredLogging": true,
      "LogSensitiveData": false,
      "MaxLogFileSizeMB": 50,
      "RetentionDays": 7,
      "CategoryOverrides": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  
  "DocumentProcessing": {
    "ChunkSize": 800,
    "ChunkOverlap": 100,
    "SupportedExtensions": [ ".pdf", ".txt", ".docx", ".md" ]
  },
  "EmbeddingModel": {
    "ModelPath": "../models/all-MiniLM-L6-v2.onnx",
    "Dimension": 384
  },
  "VectorStore": {
    "DatabasePath": "data/vectors.db"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "deepseek-r1:7b",
    "Temperature": 0.7,
    "MaxTokens": 1024
  },
  "RAG": {
    "MaxChunks": 5,
    "SimilarityThreshold": 0.7
  }
} 